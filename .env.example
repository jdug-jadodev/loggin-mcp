# =================================
# CONFIGURACIÓN DEL SERVIDOR
# =================================
PORT=3000
NODE_ENV=development

# =================================
# AUTENTICACIÓN JWT
# =================================
# JWT_SECRET: Clave secreta para firmar tokens de autenticación
# IMPORTANTE: En producción usar mínimo 64 caracteres aleatorios
# El valor debe tener al menos 32 caracteres para ser aceptado
# Generar con: openssl rand -base64 64
# Los tokens JWT tienen una duración de 15 horas
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-64-chars

# =================================
# BASE DE DATOS SUPABASE
# =================================
# URL de tu proyecto Supabase (ejemplo: https://tuproyecto.supabase.co)
SUPABASE_URL=https://your-project.supabase.co
# Anon/Public Key de tu proyecto Supabase
SUPABASE_KEY=your-supabase-anon-key-here

# =================================
# CONFIGURACIÓN OPCIONAL
# =================================
LOG_LEVEL=info
JWT_EXPIRES_IN=15h
