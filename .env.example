# =================================
# CONFIGURACIÓN DEL SERVIDOR
# =================================

# Puerto donde correrá el servidor (por defecto: 3000)
PORT=3000

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# =================================
# AUTENTICACIÓN JWT
# =================================

# Clave secreta para firmar y verificar tokens JWT
# IMPORTANTE: En producción debe ser una cadena aleatoria de mínimo 64 caracteres
# Ejemplo: puedes generar una con: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-64-characters-for-security

# =================================
# BASE DE DATOS SUPABASE
# =================================

# URL de tu proyecto Supabase
# Formato: https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Clave pública anon de Supabase (safe to use in client-side code)
SUPABASE_KEY=your-supabase-anon-key

# =================================
# CONFIGURACIÓN OPCIONAL
# =================================

# Nivel de logs (error, warn, info, debug)
LOG_LEVEL=info

# Tiempo de expiración del JWT (por defecto: 15 horas)
JWT_EXPIRES_IN=15h