# =================================
# CONFIGURACIÓN DEL SERVIDOR
# =================================
PORT=3000
NODE_ENV=development

# =================================
# AUTENTICACIÓN JWT
# =================================
# JWT_SECRET: Clave secreta para firmar tokens de autenticación
# IMPORTANTE: En producción usar mínimo 64 caracteres aleatorios
# El valor debe tener al menos 32 caracteres para ser aceptado
# Generar con: openssl rand -base64 64
# Los tokens JWT tienen una duración de 15 horas
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-64-chars

# =================================
# BASE DE DATOS SUPABASE
# =================================
# URL de tu proyecto Supabase (ejemplo: https://tuproyecto.supabase.co)
SUPABASE_URL=https://your-project.supabase.co
# Anon/Public Key de tu proyecto Supabase
SUPABASE_KEY=your-supabase-anon-key-here

# =================================
# CONFIGURACIÓN OPCIONAL
# =================================
LOG_LEVEL=info
JWT_EXPIRES_IN=15h

# =================================
# SERVICIO DE EMAIL (RESEND)
# =================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=prueba@jdug-server.com
APP_BASE_URL=http://localhost:3000

# =================================
# KEEP-ALIVE (Producción - Render.com)
# =================================
# Mantiene el servicio activo haciendo ping automático al health endpoint
# Evita que Render ponga el servicio en sleep por inactividad
# 
# KEEPALIVE_ENABLED: Activar/desactivar keep-alive (true/false)
# KEEPALIVE_URL: URL completa del health endpoint de tu servicio
# KEEPALIVE_INTERVAL_MIN: Intervalo de ping en minutos (mínimo: 1, recomendado: 10)
#
# ⚠️ IMPORTANTE: 
# - En desarrollo local: KEEPALIVE_ENABLED=false
# - En producción (Render): KEEPALIVE_ENABLED=true
# - Usa la URL real de tu servicio en Render
#
# Ejemplo para Render:
# KEEPALIVE_ENABLED=true
# KEEPALIVE_URL=https://loggin-mcp.onrender.com/health
# KEEPALIVE_INTERVAL_MIN=10
KEEPALIVE_ENABLED=false
KEEPALIVE_URL=https://your-service.onrender.com/health
KEEPALIVE_INTERVAL_MIN=10

