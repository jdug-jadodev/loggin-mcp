# =================================
# CONFIGURACIÓN DEL SERVIDOR
# =================================
PORT=3000
NODE_ENV=development

# =================================
# AUTENTICACIÓN JWT
# =================================
# IMPORTANTE: Cambiar en producción por un secreto complejo de 64+ caracteres
JWT_SECRET=your-jwt-secret-key-here

# =================================
# BASE DE DATOS SUPABASE
# =================================
# URL de tu proyecto Supabase (ejemplo: https://tuproyecto.supabase.co)
SUPABASE_URL=https://your-project.supabase.co
# Anon/Public Key de tu proyecto Supabase
SUPABASE_KEY=your-supabase-anon-key-here

# =================================
# CONFIGURACIÓN OPCIONAL
# =================================
LOG_LEVEL=info
JWT_EXPIRES_IN=15h
